# Copy to backend/.env and fill in values

# Required for AI features (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_key_here

# Optional: defaults shown
GEMINI_MODEL=gemini-1.5-flash

# JWT signing — generate a long random string for production
SECRET_KEY=change-me-use-openssl-rand-hex-32

# SQLite (default) or PostgreSQL
DATABASE_URL=sqlite:///./innocheck.db
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/innocheck

ACCESS_TOKEN_EXPIRE_MINUTES=10080
